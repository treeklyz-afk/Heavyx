<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/main_content_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="DriderX Luxury"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_network_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Syncing cloud profiles..."
            android:textColor="#8E8E93"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="#1C1C1E"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PICKUP POINT"
                android:textColor="#0A84FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_pickup"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="Current location"
                android:textColor="#FFFFFF"
                android:textColorHint="#48484A"
                android:textSize="16sp"
                android:inputType="text"
                android:importantForAutofill="no" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#38383A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FINAL DESTINATION"
                android:textColor="#30D158"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_drop"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="Where to?"
                android:textColor="#FFFFFF"
                android:textColorHint="#48484A"
                android:textSize="16sp"
                android:inputType="text"
                android:importantForAutofill="no" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_request_ride"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#FFFFFF"
            android:text="Search Available Riders"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <LinearLayout
            android:id="@+id/driver_response_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#1C1C1E"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_console_output"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loading_interface_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#0A84FF" />

        <TextView
            android:id="@+id/tv_loading_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Contacting Render allocation arrays..."
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/maintenance_block_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_alert_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="System Notice"
            android:textColor="#FF3B30"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_alert_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="DriderX infrastructure is undergoing real-time core database optimization."
            android:textColor="#E5E5EA"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_alert_action"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#1C1C1E"
            android:text="View Notice Document"
            android:textColor="#0A84FF"
            android:textAllCaps="false" />
    </LinearLayout>
</RelativeLayout>
