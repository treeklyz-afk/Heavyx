<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp">

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="DriderX Ride"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sample_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_title"
        android:layout_marginTop="8dp"
        android:text="Initializing secure core..."
        android:textColor="#8E8E93"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/location_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="@android:color/transparent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1C1E"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PICKUP LOCATION"
                android:textColor="#0A84FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_pickup"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="Where from?"
                android:textColor="#FFFFFF"
                android:textColorHint="#48484A"
                android:textSize="16sp"
                android:importantForAutofill="no"
                android:inputType="textPostalAddress" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_my="12dp"
                android:background="#38383A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="DROP OFF LOCATION"
                android:textColor="#30D158"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_drop"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="Where to?"
                android:textColor="#FFFFFF"
                android:textColorHint="#48484A"
                android:textSize="16sp"
                android:importantForAutofill="no"
                android:inputType="textPostalAddress" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_find_driver"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#FFFFFF"
            android:text="Request DriderX"
            android:textColor="#000000"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/result_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/location_card"
        android:layout_marginTop="20dp"
        android:background="#1C1C1E"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/tv_driver_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="normal" />
    </LinearLayout>

</RelativeLayout>
